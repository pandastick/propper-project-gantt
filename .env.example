# PPGantt server config
# Copy this file to .env and edit as needed.

# Port the Express server listens on (default 8080)
PORT=8080

# Optional: path to a private data directory outside this repo.
# When set, the server loads _manifest.json and data files from here
# instead of the local ./data folder.
#
# Example (absolute path):
#   DATA_DIR=/Users/you/my-ppgantt-data/data
#
# Example (home expansion — '~' works):
#   DATA_DIR=~/my-ppgantt-data/data
#
# DATA_DIR=
