# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# Notion Integration token (get from https://www.notion.so/my-integrations)
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL: path to a shared workspace repo's roadmap file. When set, the
# sync script copies roadmap.json to this path, commits, and pushes after
# each successful sync. Useful for team collaboration — leave unset for
# solo / purely-local use.
# PPGANTT_ROADMAP_PATH=/absolute/path/to/your-shared-repo/roadmap/roadmap.json
